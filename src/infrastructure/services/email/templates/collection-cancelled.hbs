{{#> layout title="A sua recolha foi cancelada"}}

  {{> eyebrow text="RECOLHA CANCELADA"}}

  <!-- Body -->
  <tr>
    <td style="padding:20px 40px 8px;">
      <p style="margin:0 0 12px;font-size:15px;color:#333333;">
        Olá, <strong style="color:#02748E;">{{firstName}} {{lastName}}</strong>!
      </p>
      <p style="margin:0 0 12px;font-size:15px;color:#333333;line-height:1.6;">
        Informamos que a recolha da sua solicitação{{#if friendlyCode}}
        (código <strong style="color:#02748E;">{{friendlyCode}}</strong>){{/if}}
        foi <strong>cancelada</strong>.
      </p>
    </td>
  </tr>

  <!-- Motivo -->
  <tr>
    <td style="padding:0 40px 8px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0"
        style="border:1px solid #e8e8e8;border-radius:8px;background-color:#F6F6F6;">
        <tr>
          <td style="padding:14px 20px;font-size:14px;color:#7F7F7F;">Motivo</td>
        </tr>
        <tr>
          <td style="padding:0 20px 14px;font-size:15px;color:#013364;line-height:1.6;">
            {{reason}}
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <tr>
    <td style="padding:16px 40px 32px;">
      <p style="margin:0 0 12px;font-size:15px;color:#333333;line-height:1.6;">
        Se pretender reagendar, poderá criar uma nova solicitação de recolha.
      </p>
      <p style="margin:0;font-size:15px;color:#333333;">
        A sua equipa <strong>RETEX Portugal</strong>
      </p>
    </td>
  </tr>

{{/layout}}

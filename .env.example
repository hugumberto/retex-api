PORT=3000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@postgresdb:5432/retex
APPLICATION_NAME=retex
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Retex <noreply@example.com>"
PORTAL_URL=http://localhost:3002
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRES_IN=1d
# Seed do admin: se definidos, criam o utilizador admin no arranque (dev e prod).
# Em dev, se omitidos, é usado o fallback admin@retex.pt / 123456.
ADMIN_EMAIL=admin@retex.pt
ADMIN_PASSWORD=change-me
# Base URL dos assets/imagens usados nos emails (ex.: logo). Sem barra final.
ASSETS_BASE_URL=https://www.retex.pt
# Email que recebe as mensagens do formulário de contacto da landing.
# Se omitido, é usado geral@retex.pt.
CONTACT_EMAIL=geral@retex.pt
# Geocodificação de endereços via TomTom (usado no cadastro de morada e no
# script geocode:backfill). Opcional: sem a key o geocoding é ignorado.
TOMTOM_API_KEY=your-tomtom-key
# Base do endpoint de geocode (opcional; default: API pública da TomTom).
# TOMTOM_GEOCODE_URL=https://api.tomtom.com/search/2/geocode/
